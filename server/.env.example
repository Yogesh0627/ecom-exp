# ==============================================================================
# EcoExpress backend configuration — EXAMPLE
# ------------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values, then run the backend.
#     cp .env.example .env          (Windows: copy .env.example .env)
#
# Only the DATABASE and JWT_SECRET are REQUIRED. Everything below the line
# "OPTIONAL INTEGRATIONS" can be left blank — those features just switch off.
# ==============================================================================

# ---- Database (REQUIRED) -----------------------------------------------------
# Local Postgres (see SETUP.md step 3):
DB_URL=jdbc:postgresql://localhost:5432/ecoexpress
DB_USERNAME=ecoexpress
DB_PASSWORD=ecoexpress
# Using Neon (cloud)? Use their string WITH a "jdbc:" prefix, e.g.:
#   DB_URL=jdbc:postgresql://ep-xxxx.aws.neon.tech/neondb?sslmode=require

# ---- Security (REQUIRED) -----------------------------------------------------
# Any random string of at least 32 characters. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# ---- First admin account (created once, on first startup) --------------------
# The ONLY way to reach the admin dashboard initially. A restart never resets a
# password you later change. Remove these in production and create an admin
# out-of-band.
ecoexpress.bootstrap.admin-email=admin@ecoexpress.in
ecoexpress.bootstrap.admin-password=ChangeMe-EcoAdmin-2026
ecoexpress.bootstrap.admin-name=Admin

# ==============================================================================
# OPTIONAL INTEGRATIONS — leave blank to disable the feature cleanly
# ==============================================================================

# ---- AI (Google Gemini) ------------------------------------------------------
# Free key: https://aistudio.google.com/app/apikey
# Blank => AI features (Smart Fridge, Meal Planner, recipes) return a clean 503.
GEMINI_API_KEY=
ecoexpress.ai.api-key=${GEMINI_API_KEY}
ecoexpress.ai.model=gemini-flash-latest
ecoexpress.ai.monthly-budget-inr=5000

# ---- Google sign-in (OAuth) --------------------------------------------------
# Only used under the "google-oauth" profile. Create credentials at
# https://console.cloud.google.com  ->  APIs & Services  ->  Credentials.
# Add this Authorized redirect URI:
#   http://localhost:8081/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Payments (Razorpay, use TEST mode) --------------------------------------
# Dashboard (Test Mode): key-id/secret under Settings > API Keys;
# webhook-secret under Settings > Webhooks (a DIFFERENT value from key-secret).
# Blank key-id => checkout returns "payments are not configured".
ecoexpress.razorpay.key-id=
ecoexpress.razorpay.key-secret=
ecoexpress.razorpay.webhook-secret=

# ---- Email (Resend) ----------------------------------------------------------
# Key: https://resend.com  — blank => emails are skipped (in-app notices only).
RESEND_API_KEY=
EMAIL_FROM=EcoExpress <onboarding@resend.dev>

# ---- Cache (Upstash Redis) — only used under the "prod" profile --------------
# Local dev uses an in-process cache and ignores these. Leave blank for local.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- File storage ------------------------------------------------------------
# "local" saves uploads to ./storage (no keys needed). Use "s3" for Cloudflare
# R2 / AWS S3 and fill in the S3_* values below.
STORAGE_PROVIDER=local
STORAGE_DIR=./storage
APP_BASE_URL=http://localhost:8081

# Only needed when STORAGE_PROVIDER=s3 (R2 is S3-compatible).
# S3_ENDPOINT is the ACCOUNT endpoint with NO bucket in the path.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ---- Invoice seller identity (printed on PDF tax invoices) -------------------
# Change to your registered business details before issuing real invoices.
# GSTIN and FSSAI are legally required on an Indian tax invoice.
INVOICE_SELLER_NAME=EcoExpress Organics Pvt Ltd
INVOICE_SELLER_GSTIN=29ABCDE1234F1Z5
INVOICE_SELLER_FSSAI=10012345678901
INVOICE_SELLER_ADDRESS=123 Example Street
INVOICE_SELLER_CITY=New Delhi
INVOICE_SELLER_STATE=Delhi
INVOICE_SELLER_PINCODE=110001
INVOICE_SELLER_EMAIL=support@ecoexpress.in
INVOICE_SELLER_PHONE=+91 80 4000 0000
