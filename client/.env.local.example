# ==============================================================================
# EcoExpress frontend configuration — EXAMPLE
# ------------------------------------------------------------------------------
# Copy this file to ".env.local", then run the frontend:
#     cp .env.local.example .env.local   (Windows: copy .env.local.example .env.local)
#
# Note: every variable is prefixed NEXT_PUBLIC_ because it is read in the browser.
# These are baked in at build time — after changing them, restart / rebuild.
# ==============================================================================

# ---- Where the backend API lives (REQUIRED) ----------------------------------
# For local development this points at the backend on port 8081.
# It MUST end with /api/v1.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1

# ---- The site's own public URL (used for SEO: sitemap, canonical, share cards)
# Local default is fine for development. In production set your real domain,
# e.g. https://ecoexpress-nu.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Demo login buttons ------------------------------------------------------
# The login page shows "As User" / "As Admin" one-click buttons. On by default.
# Set to "false" to hide them.
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true

# ---- Payment test-mode note --------------------------------------------------
# Shows the test-card hint at checkout so users know it's a test transaction.
# On by default; set to "false" to hide.
# NEXT_PUBLIC_PAYMENTS_TEST_MODE=true
